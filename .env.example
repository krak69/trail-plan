# Copie ce fichier en .env.local et remplis les valeurs depuis ton projet Supabase :
# Supabase Dashboard -> Project Settings -> Data API (ou API) -> Project URL & anon key.
# Ces mêmes variables devront être ajoutées dans Vercel (Project Settings -> Environment Variables).

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...votre_cle_anon...
